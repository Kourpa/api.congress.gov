    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2025-06-17</actionDate>
        <actionDesc>Introduced in House</actionDesc>
        <updateDate>2026-06-01T11:35:26Z</updateDate>
        <text><![CDATA[<p>This resolution provides&nbsp;for the consideration of&nbsp;H.R. 2913, the Ukraine Support Act. It also provides that the Clerk of the House&nbsp;shall transmit to the Senate a message that the House has passed H.R. 2913 no later than one week after the bill's passage.</p>]]></text>
      </summary>
