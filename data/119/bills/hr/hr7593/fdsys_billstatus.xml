      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>To amend title 37, United States Code, to reimburse a member of the uniformed services for costs incurred to rent a motor vehicle for travel relating to a period of reserve component inactive-duty training, or of Ready Reserve muster duty, performed more than 150 miles from the member's permanent residence.</title>
        <updateDate>2026-02-25T03:48:22Z</updateDate>
