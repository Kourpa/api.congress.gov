      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>To prohibit the United States Postal Service from finalizing, implementing, or enforcing a proposed rule with respect to the mailing of pistols, revolvers, and other firearms capable of being concealed on the person.</title>
