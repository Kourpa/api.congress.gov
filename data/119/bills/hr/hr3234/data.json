  "introduced_at": "2025-05-07",
  "number": "3234",
  "official_title": "To amend the Federal Deposit Insurance Act to modify the amount of reciprocal deposits of an insured depository institution that are not considered to be funds obtained by or through a deposit broker, and for other purposes.",
  "popular_title": null,
  "related_bills": [
