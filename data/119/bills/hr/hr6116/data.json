  "introduced_at": "2025-11-18",
  "number": "6116",
  "official_title": "To amend the Safe Drinking Water Act to require testing of underground sources of drinking water in connection with hydraulic fracturing operations, and for other purposes.",
  "popular_title": null,
  "related_bills": [],
  "short_title": "Safe Hydration is an American Right in Energy Development Act of 2025",
  "sponsor": {
