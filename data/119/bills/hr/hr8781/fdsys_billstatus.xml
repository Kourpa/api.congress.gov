      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>To clarify that for purposes of Federal nondiscrimination requirements applicable to education programs or activities receiving Federal financial assistance, discrimination prohibited under title IX of the Education Amendments of 1972 is based on the biological reality of sex.</title>
        <updateDate>2026-05-27T08:18:41Z</updateDate>
        <billTextVersionName>Introduced in House</billTextVersionName>
        <billTextVersionCode>IH</billTextVersionCode>
