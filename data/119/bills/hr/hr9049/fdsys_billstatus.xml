        <title>Stopping Hidden Interests and Non-disclosure in Elections Act</title>
        <updateDate>2026-06-06T09:53:23Z</updateDate>
        <billTextVersionName>Introduced in House</billTextVersionName>
        <billTextVersionCode>IH</billTextVersionCode>
