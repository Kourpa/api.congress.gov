    <summaries>
      <summary>
        <versionCode>07</versionCode>
        <actionDate>2026-04-02</actionDate>
        <actionDesc>Reported to House</actionDesc>
        <updateDate>2026-05-29T14:19:59Z</updateDate>
        <text><![CDATA[<p><strong>Benton MacKaye National Scenic Trail Feasibility Study Act of 2026</strong></p><p>This bill requires the Department of Agriculture to study the feasibility of designating the Benton&nbsp;MacKaye Trail (located in Georgia, Tennessee, and North Carolina) as a national scenic trail.</p>]]></text>
      </summary>
