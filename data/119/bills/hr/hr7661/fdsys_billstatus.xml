      <item>
        <titleType>Short Title(s) as Introduced</titleType>
        <titleTypeCode>101</titleTypeCode>
        <title>Stop the Sexualization of Children Act</title>
        <updateDate>2026-02-25T09:23:22Z</updateDate>
        <billTextVersionName>Introduced in House</billTextVersionName>
        <billTextVersionCode>IH</billTextVersionCode>
      </item>
      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>To amend the Elementary and Secondary Education Act of 1965 to prohibit the use of funds provided under such Act to develop, implement, facilitate, host, or promote any program or activity for, or to provide or promote literature or other materials to, children under the age of 18 that includes sexually oriented material, and for other purposes.</title>
        <updateDate>2026-02-25T09:18:37Z</updateDate>
        <billTextVersionName>Introduced in House</billTextVersionName>
        <billTextVersionCode>IH</billTextVersionCode>
      </item>
