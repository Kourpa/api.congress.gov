    <summaries>
      <summary>
        <versionCode>07</versionCode>
        <actionDate>2026-02-11</actionDate>
        <actionDesc>Reported to House</actionDesc>
        <updateDate>2026-02-26T19:37:33Z</updateDate>
        <text><![CDATA[<p><strong>Territorial Student Access to Higher Education Act</strong></p><p>This bill requires public institutions of higher education that participate in federal student aid programs to charge no more than in-state tuition and fee rates to students who&nbsp;are residents of Guam, the Northern Mariana Islands, American Samoa, or the U.S. Virgin Islands, provided they are also U.S. nationals.</p>]]></text>
      </summary>
    </summaries>
