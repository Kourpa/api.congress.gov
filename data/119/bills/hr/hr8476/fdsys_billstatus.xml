        <title>No Antisemitism in Education Act of 2026</title>
        <updateDate>2026-05-05T06:08:27Z</updateDate>
      </item>
      <item>
        <titleType>Short Title(s) as Introduced</titleType>
        <titleTypeCode>101</titleTypeCode>
        <title>No Antisemitism in Education Act of 2026</title>
        <updateDate>2026-05-05T06:08:26Z</updateDate>
        <billTextVersionName>Introduced in House</billTextVersionName>
        <billTextVersionCode>IH</billTextVersionCode>
      </item>
      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>To require each local educational agency and institution of higher education that receives Federal financial assistance to treat discrimination motivated by antisemitism as vigorously as such agency or institution treats other forms of discrimination prohibited by title VI of the Civil Rights Act of 1964, and for other purposes.</title>
        <updateDate>2026-05-05T06:03:36Z</updateDate>
        <billTextVersionName>Introduced in House</billTextVersionName>
        <billTextVersionCode>IH</billTextVersionCode>
      </item>
