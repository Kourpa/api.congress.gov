      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>To require States to consider legal issues affecting youth as part of case planning and to provide States with the option to use funds from the John H. Chafee Foster Care Program for Successful Transition to Adulthood to support access to legal services and counseling.</title>
        <updateDate>2026-02-24T09:48:39Z</updateDate>
