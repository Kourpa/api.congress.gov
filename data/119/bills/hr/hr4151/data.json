  "introduced_at": "2025-06-26",
  "number": "4151",
  "official_title": "To amend the Older Americans Act of 1965 to provide equal treatment of LGBTQI older individuals, and for other purposes.",
  "popular_title": null,
  "related_bills": [],
  "short_title": "Ruthie and Connie LGBTQI Elder Americans Act of 2025",
  "sponsor": {
