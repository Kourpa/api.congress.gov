    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2025-12-03</actionDate>
        <actionDesc>Introduced in House</actionDesc>
        <updateDate>2026-02-24T17:27:19Z</updateDate>
        <text><![CDATA[<p><strong>Reducing and Eliminating Duplicative Environmental Regulations Act or the RED Tape Act</strong></p><p>This bill removes the requirement under the Clean Air Act that the Environmental Protection Agency (EPA) review and comment on newly authorized federal construction projects and other major federal agency actions that already require review under the National Environmental Policy Act (NEPA) and proposed federal regulations.</p>]]></text>
      </summary>
    </summaries>
