  "introduced_at": "2025-06-10",
  "number": "3859",
  "official_title": "To amend the Immigration and Nationality Act to provide for the removal and permanent inadmissibility of certain aliens convicted of assaulting law enforcement officers, and for other purposes.",
  "popular_title": null,
  "related_bills": [],
  "short_title": "Returning Illegals over Turmoil Act",
  "sponsor": {
    "bioguide_id": "C001120",
