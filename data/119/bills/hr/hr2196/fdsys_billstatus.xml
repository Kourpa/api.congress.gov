      <summary>
        <versionCode>07</versionCode>
        <actionDate>2026-02-24</actionDate>
        <actionDesc>Reported to House</actionDesc>
        <updateDate>2026-03-12T14:12:13Z</updateDate>
        <text><![CDATA[<p><strong>National Emergency Medical Services Memorial Extension Act</strong></p><p>This bill reauthorizes the National Emergency Medical Services Memorial Foundation to establish&nbsp;in Washington, DC, a monument to commemorate the commitment and service represented by emergency medical services. This authorization expires seven years after enactment of the bill.</p>]]></text>
      </summary>
    </summaries>
