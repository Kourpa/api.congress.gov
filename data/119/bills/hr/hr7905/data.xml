  <titles>
    <title type="display">Diabetes Foot Health Access and Modernization Act of 2026</title>
    <title type="short" as="introduced">Diabetes Foot Health Access and Modernization Act of 2026</title>
    <title type="official" as="introduced">To amend title XIX of the Social Security Act to cover physician services delivered by podiatric physicians to ensure access by Medicaid beneficiaries to appropriate quality foot and ankle care, to amend title XVIII of such Act to modify the requirements for diabetic shoes to be included under Medicare, and for other purposes.</title>
  </titles>
