      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>To amend title XIX of the Social Security Act to cover physician services delivered by podiatric physicians to ensure access by Medicaid beneficiaries to appropriate quality foot and ankle care, to amend title XVIII of such Act to modify the requirements for diabetic shoes to be included under Medicare, and for other purposes.</title>
