      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>To direct the Administrator of the Centers for Medicare &amp; Medicaid Services to implement the Perinatal Care Alternative Payment Model Demonstration Project to test various payment models with respect to maternity care provided to pregnant and postpartum individuals, and for other purposes.</title>
