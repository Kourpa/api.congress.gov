  "introduced_at": "2025-02-27",
  "number": "1707",
  "official_title": "To amend the Internal Revenue Code of 1986 to establish a tax credit to incentivize the purchase of American agricultural commodities.",
  "popular_title": null,
  "related_bills": [],
  "short_title": "Grown in America Act of 2025",
  "sponsor": {
    "bioguide_id": "K000392",
    "district": "8",
    "name": "Kustoff, David",
    "state": "TN",
    "title": "Rep.",
