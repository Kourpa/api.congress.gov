  "introduced_at": "2025-03-06",
  "number": "1903",
  "official_title": "To amend the Trade Expansion Act of 1962 to impose limitations on the authority of the President to adjust imports that are determined to threaten to impair national security, and for other purposes.",
  "popular_title": null,
