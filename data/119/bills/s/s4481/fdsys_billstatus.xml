      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>A bill to require the Secretary of Health and Human Services to establish a demonstration project to allow States to test payment models for maternity care provided to pregnant and postpartum individuals under the Medicaid and CHIP programs, and for other purposes.</title>
