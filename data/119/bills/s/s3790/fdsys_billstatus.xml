      <item>
        <titleType>Official Title as Introduced</titleType>
        <titleTypeCode>6</titleTypeCode>
        <title>A bill to condition certain Federal funds for States and local governments on cooperation with Federal immigration enforcement authorities, to deter illegal entry and reentry into the United States, to increase criminal penalties for crimes committed after illegal reentry into the United States, to protect Federal officers and employees from agitators using loud noises to interfere with the performance of their official duties, and to exclude organization that promote, incite, or provide material support for criminal violence from the tax benefits available under section 501(c)(3) of the Internal Revenue Code of 1986.</title>
        <updateDate>2026-02-26T07:48:36Z</updateDate>
        <billTextVersionName>Introduced in Senate</billTextVersionName>
        <billTextVersionCode>IS</billTextVersionCode>
      </item>
